{
  "name": "crud-veiculo",
  "version": "1.0.0",
  "description": "CRUD de veiculos com Node.js, JSON file storage e testes Mocha",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts",
    "test": "mocha --require ts-node/register --recursive \"test/**/*.test.ts\"",
    "test:coverage": "c8 --all --include=src/**/*.ts --exclude=src/server.ts --reporter=text --reporter=html npm test"
  },
  "keywords": [
    "nodejs",
    "crud",
    "clean-architecture",
    "mocha",
    "express"
  ],
  "author": "Damia",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "mocha": "^11.7.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
